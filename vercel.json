{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/pages/$1"
    },
    {
      "src": "/auth(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/barang(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/lelang(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/pembayaran(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    }
  ]
}
